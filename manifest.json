{
  "id": "violation-tracking",
  "name": "Violation Tracking",
  "version": "1.0.0",
  "description": "Board issues CC&R violation notices to units; homeowners acknowledge, respond, or dispute; board tracks through resolution or escalation.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "organization",
  "tags": [
    "hoa",
    "violations",
    "ccr",
    "compliance",
    "board"
  ],
  "data_access": {
    "reads": [
      "family.members",
      "family.groups"
    ],
    "writes": []
  },
  "exports": [
    "pending_violations"
  ],
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": true
  },
  "storage": "db",
  "row_policies": {
    "settings": {
      "kind": "app_config"
    },
    "violations": {
      "kind": "owner_only",
      "member_column": "unit_id",
      "adults_bypass": false,
      "member_can_update": false,
      "insert_privileged_only": true,
      "delete_privileged_only": true,
      "privileged_groups": [
        {
          "settings_table": "settings",
          "settings_key": "board_group_id"
        }
      ],
      "audit_writes": true
    },
    "activity": {
      "kind": "inherit_visibility",
      "fk_column": "violation_id",
      "parent_table": "violations",
      "writer_column": "actor_id",
      "audit_writes": true
    }
  },
  "admin_config": {
    "settings_table": "settings",
    "keys": [
      "board_group_id"
    ]
  },
  "notification_acls": {
    "send": {
      "require_group_setting": {
        "settings_table": "settings",
        "settings_key": "board_group_id"
      }
    }
  },
  "export_acls": {
    "pending_violations": {
      "require_group_setting": {
        "settings_table": "settings",
        "settings_key": "board_group_id"
      }
    }
  },
  "store_acls": {
    "pending_violations": {
      "read": {
        "require_group_setting": {
          "settings_table": "settings",
          "settings_key": "board_group_id"
        }
      },
      "write": {
        "require_group_setting": {
          "settings_table": "settings",
          "settings_key": "board_group_id"
        }
      }
    }
  },
  "nav": {
    "label": "Violations"
  },
  "icon": "\u26a0\ufe0f"
}
